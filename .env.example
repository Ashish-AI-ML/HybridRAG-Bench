# ============================================================
# HybridRAG Bench — Environment Configuration Template
# Copy this file to .env and fill in your values.
# ============================================================

# --- LLM Provider ---
# Supported: "gemini", "openai", "mock"
LLM_PROVIDER=gemini

# Google Gemini API Key (if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# --- Qdrant Vector Store ---
# Use "local" for in-process (no server needed) or "cloud" for Qdrant Cloud
QDRANT_MODE=local

# Qdrant Cloud URL + Key (only needed if QDRANT_MODE=cloud)
QDRANT_URL=https://your-cluster.qdrant.tech
QDRANT_API_KEY=your_qdrant_api_key_here

# Local Qdrant persistence path (only used if QDRANT_MODE=local)
QDRANT_LOCAL_PATH=./qdrant_storage

# --- App Configuration ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Evaluation ---
# LLM judge for faithfulness evaluation: "gemini", "openai", or "heuristic"
EVAL_JUDGE=gemini
